{
  "name": "unseen",
  "version": "0.1.0",
  "private": true,
  "description": "End-to-end encrypted, one-time private session chat over a Bun relay",
  "keywords": [
    "bun",
    "chat",
    "e2ee",
    "end-to-end-encryption",
    "ephemeral",
    "lit",
    "opfs",
    "prf",
    "web-platform",
    "webauthn"
  ],
  "homepage": "https://unseen.fyi",
  "license": "MIT",
  "author": {
    "name": "Alexey Simonenko",
    "email": "alexey@simonenko.dev",
    "url": "http://simonenko.xyz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meritt/unseen.fyi.git"
  },
  "workspaces": [
    "shared",
    "client",
    "server"
  ],
  "type": "module",
  "scripts": {
    "ci": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run perf:bundle-size",
    "lint": "oxlint --type-aware",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsgo --noEmit -p shared/tsconfig.json && tsgo --noEmit -p client/tsconfig.json && tsgo --noEmit -p server/tsconfig.json && tsgo --noEmit -p tsconfig.json",
    "test": "bun test shared client server --preload ./client/test/_helpers/dom-globals.ts",
    "test:e2e": "playwright test --config=test/playwright.config.ts",
    "build:client": "bun run --cwd client build.ts",
    "dev:server": "BUN_FEATURE_FLAG_NO_ORPHANS=1 UNSEEN_ALLOWED_ORIGINS=http://localhost:5173 bun run server/src/index.ts",
    "dev:client": "BUN_FEATURE_FLAG_NO_ORPHANS=1 bun run --cwd client dev-server.ts",
    "perf:bundle-size": "NODE_ENV=production UNSEEN_WS_URL=/ws bun run --cwd client build.ts && bun run test/perf/bundle-size.ts",
    "perf:lighthouse": "BUN_FEATURE_FLAG_NO_ORPHANS=1 bun run test/perf/lighthouse.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "1.60.0",
    "@types/bun": "1.3.14",
    "@typescript/native-preview": "7.0.0-dev.20260615.1",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^13.4.0",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "oxlint-tsgolint": "0.23.0"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14"
}
